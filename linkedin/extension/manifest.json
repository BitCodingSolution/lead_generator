{
  "manifest_version": 3,
  "name": "Pradip AI — Lead Tracker",
  "version": "0.8.0",
  "description": "Bulk-open curated LinkedIn search URLs, auto-scan results for hiring posts + contact info, save to Google Sheet with Claude-generated outreach emails, draft human-sounding replies for LinkedIn messages, and generate LinkedIn post drafts for Jaydip's own feed.",
  "permissions": ["storage", "tabs", "scripting", "activeTab", "sidePanel", "alarms", "notifications"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.anthropic.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Pradip AI Lead Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/messaging/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://www.linkedin.com/search/results/content/*"],
      "js": ["search-scan.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/feed/*"],
      "js": ["feed-compose.js"],
      "run_at": "document_idle"
    }
  ]
}
