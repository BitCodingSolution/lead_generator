# Copy to .env and fill in. Anything left blank uses the documented defaults.

# ---- Auth ----
# JWT signing secret. Auto-generated and persisted to <backend>/.jwt_secret
# on first boot if unset.
DASHBOARD_JWT_SECRET=

# Optional CORS additions and rate limit (RPM, per IP).
DASHBOARD_EXTRA_ORIGINS=
DASHBOARD_RATE_LIMIT=120
DASHBOARD_DOCS=1

# ---- Outlook (Marcel pipeline) ----
OUTLOOK_ACCOUNT=

# ---- Local Claude bridge ----
BRIDGE_DIR=
BRIDGE_URL=

# ---- Postgres (linkedin_db tests) ----
DATABASE_URL=
