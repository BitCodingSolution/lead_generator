{
  "source": "ycombinator",
  "type": "grab",
  "source_url_pattern": "https://www.ycombinator.com/companies/{slug}",

  "api": {
    "endpoint": "https://45bwzj1sgc-dsn.algolia.net/1/indexes/YCCompany_production/query",
    "app_id": "45BWZJ1SGC",
    "api_key_location": "window.AlgoliaOpts on https://www.ycombinator.com/companies (public search-only key, rotates occasionally)",
    "auth": "none"
  },

  "total_companies_approx": 5845,
  "facets_available": ["batch", "regions", "industry", "isHiring", "tags", "subindustry", "status", "stage"],
  "fields_provided": [
    "id", "name", "slug", "website", "all_locations", "long_description", "one_liner",
    "team_size", "industry", "subindustry", "launched_at", "tags", "top_company",
    "isHiring", "nonprofit", "batch", "status", "industries", "regions", "stage"
  ],
  "signal_types": {
    "yc_active_hiring": "isHiring=true",
    "yc_recent_batch": "batch in last 4 cohorts",
    "yc_portfolio": "catch-all for any YC company matching ICP filters"
  },
  "person_enrichment": "Founders available via YC detail page (name, title, linkedin). Emails via pattern+verify.",

  "display": {
    "icon": "Rocket",
    "label": "Y Combinator",
    "description": "YC portfolio companies — funded, US-heavy, actively hiring",
    "table_columns": [
      {"key": "company_name",        "label": "Company",  "width": 180, "primary": true},
      {"key": "extra.batch",         "label": "Batch",    "width": 110},
      {"key": "extra.team_size",     "label": "Team",     "width": 70,  "align": "right"},
      {"key": "extra.industry",      "label": "Industry", "width": 120},
      {"key": "location",            "label": "Location", "width": 180, "truncate": true},
      {"key": "extra.stage",         "label": "Stage",    "width": 90,  "badge": true},
      {"key": "extra.is_hiring",     "label": "Hiring",   "width": 70,  "type": "bool"},
      {"key": "signal_type",         "label": "Signal",   "width": 140, "badge": true},
      {"key": "company_domain",      "label": "Domain",   "width": 160, "type": "url"}
    ],
    "filters": [
      {"key": "extra.batch",      "type": "dropdown", "label": "Batch",    "facet": true},
      {"key": "extra.industry",   "type": "dropdown", "label": "Industry", "facet": true},
      {"key": "extra.stage",      "type": "dropdown", "label": "Stage",    "facet": true},
      {"key": "extra.is_hiring",  "type": "toggle",   "label": "Hiring only"},
      {"key": "has_email",        "type": "toggle",   "label": "Has verified email"}
    ],
    "search_fields": ["company_name", "extra.one_liner", "extra.tags"],
    "founder_display": {
      "enabled": true,
      "expand_row": true,
      "columns": ["full_name", "title", "email", "email_status", "linkedin_url"]
    }
  },

  "scraper": {
    "path": "sources/ycombinator/scraper.py",
    "default_args": ["--hiring-only", "--us-only"],
    "option_args": [
      {"flag": "--limit",        "type": "int",    "label": "Limit"},
      {"flag": "--hiring-only",  "type": "bool",   "label": "Hiring only",   "default": true},
      {"flag": "--us-only",      "type": "bool",   "label": "US only",       "default": true},
      {"flag": "--batch",        "type": "string", "label": "Batch",         "placeholder": "Summer 2024"},
      {"flag": "--industry",     "type": "string", "label": "Industry",      "placeholder": "B2B"}
    ]
  },

  "enricher": {
    "path": "common/enrich.py",
    "default_args": ["--source", "ycombinator"]
  }
}
