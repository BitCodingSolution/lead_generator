{
  "manifest_version": 3,
  "name": "BitCoding — LinkedIn Outreach",
  "version": "1.0.0",
  "description": "Scan LinkedIn search results for hiring posts + contact info and send them to the BitCoding dashboard. Draft human-sounding DM replies and LinkedIn post variants via Claude.",
  "permissions": ["storage", "tabs", "scripting", "activeTab", "sidePanel", "alarms", "notifications", "webNavigation"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.anthropic.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "BitCoding — LinkedIn Outreach",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/messaging/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://www.linkedin.com/search/results/content/*"],
      "js": ["search-scan.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/feed/*"],
      "js": ["feed-compose.js"],
      "run_at": "document_idle"
    }
  ]
}
