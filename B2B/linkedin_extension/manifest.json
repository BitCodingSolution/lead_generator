{
  "manifest_version": 3,
  "name": "BitCoding — LinkedIn Outreach",
  "version": "1.0.0",
  "description": "Scans LinkedIn posts and sends them to the BitCoding dashboard at localhost:8900. No Google Sheet, no Claude key in the browser.",
  "permissions": ["storage", "tabs", "scripting", "activeTab", "sidePanel"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:8900/*",
    "http://127.0.0.1:8900/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "BitCoding — LinkedIn Outreach"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/search/results/content/*"],
      "js": ["search-scan.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/messaging/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://www.linkedin.com/feed/*"],
      "js": ["feed-compose.js"],
      "run_at": "document_idle"
    }
  ]
}
